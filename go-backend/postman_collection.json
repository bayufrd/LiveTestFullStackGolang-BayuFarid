      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"product\": {\n    \"name\": \"Laptop\",\n    \"price\": 1200\n  },\n  \"taxRate\": 0.07\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/product/price-with-tax",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "product",
            "price-with-tax"
          ]
        }
      }
    },
    {
      "name": "Calculate Average",
      "request": {
        "method": "POST",
